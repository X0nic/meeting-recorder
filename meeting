#!/usr/bin/env bash
set -euo pipefail

MEETINGS_DIR="${MEETINGS_DIR:-$HOME/Documents/meetings}"
STATE_DIR="${STATE_DIR:-$HOME/.meeting-recorder}"
STATE_FILE="$STATE_DIR/current"
CONFIG_FILE="$STATE_DIR/config"
SILENCE_THRESHOLD_DB="${SILENCE_THRESHOLD_DB:--50}"

ensure_dirs() {
  mkdir -p "$MEETINGS_DIR" "$STATE_DIR"
}

ffmpeg_list_devices() {
  ffmpeg -f avfoundation -list_devices true -i "" 2>&1
}

parse_devices() {
  local type="$1" # video|audio
  local section=""
  ffmpeg_list_devices | awk -v want="$type" '
    /AVFoundation video devices:/ {section="video"; next}
    /AVFoundation audio devices:/ {section="audio"; next}
    section==want && /\[[0-9]+\]/ {
      match($0, /\[[0-9]+\] .*/)
      print substr($0, RSTART, RLENGTH)
    }
  '
}

list_devices_pretty() {
  local type="$1"
  parse_devices "$type" | while IFS= read -r line; do
    local idx name
    idx="${line%%]*}"
    idx="${idx#*[}"
    name="${line#*] }"
    printf "%s\t%s\n" "$idx" "$name"
  done
}

label_screen() {
  local name="$1"
  if [[ "$name" == Capture\ screen* ]]; then
    echo "screen"
  else
    echo "camera"
  fi
}

list_screens() {
  local devices
  devices=$(list_devices_pretty video || true)
  if [[ -z "$devices" ]]; then
    echo ""
    return
  fi
  echo "$devices" | while IFS=$'\t' read -r idx name; do
    printf "%s\t%s\t%s\n" "$idx" "$name" "$(label_screen "$name")"
  done
}

list_audio_devices() {
  list_devices_pretty audio || true
}

get_screen_bounds() {
  osascript <<'OSA'
use framework "AppKit"
use scripting additions
set screens to current application's NSScreen's screens()
set out to ""
set idx to 0
repeat with s in screens
  set f to s's frame() as list
  set o to item 1 of f
  set sz to item 2 of f
  set x to (item 1 of o) as integer
  set y to (item 2 of o) as integer
  set w to (item 1 of sz) as integer
  set h to (item 2 of sz) as integer
  set out to out & idx & tab & x & tab & y & tab & w & tab & h & linefeed
  set idx to idx + 1
end repeat
return out
OSA
}

get_meeting_app_windows() {
  echo "[debug] Running meeting app detection..." >&2
  local result
  result=$(osascript <<'OSA'
use scripting additions
set output to ""
set debugLog to ""
tell application "System Events"
  set appNames to {"Microsoft Teams", "MSTeams", "zoom.us", "Google Chrome", "Slack", "Webex", "FaceTime"}
  repeat with appName in appNames
    set appStr to appName as text
    if exists (application process appStr) then
      set debugLog to debugLog & "[debug] Found process: " & appStr & linefeed
      tell application process appStr
        set wcount to count of windows
        set debugLog to debugLog & "[debug]   Window count: " & wcount & linefeed
        repeat with w in windows
          set wtitle to ""
          try
            set wtitle to name of w
          end try
          set debugLog to debugLog & "[debug]   Window: " & wtitle & linefeed
          if appStr is "Google Chrome" then
            if wtitle does not contain "meet.google.com" then
              -- skip non-Meet windows
            else
              try
                set pos to position of w
                set sz to size of w
                set debugLog to debugLog & "[debug]   pos=" & (item 1 of pos) & "," & (item 2 of pos) & " size=" & (item 1 of sz) & "," & (item 2 of sz) & linefeed
                set output to output & appStr & tab & (item 1 of pos) & tab & (item 2 of pos) & tab & (item 1 of sz) & tab & (item 2 of sz) & linefeed
              on error errMsg
                set debugLog to debugLog & "[debug]   ERROR getting pos/size: " & errMsg & linefeed
              end try
              exit repeat
            end if
          else
            try
              set pos to position of w
              set sz to size of w
              set debugLog to debugLog & "[debug]   pos=" & (item 1 of pos) & "," & (item 2 of pos) & " size=" & (item 1 of sz) & "," & (item 2 of sz) & linefeed
              set output to output & appStr & tab & (item 1 of pos) & tab & (item 2 of pos) & tab & (item 1 of sz) & tab & (item 2 of sz) & linefeed
            on error errMsg
              set debugLog to debugLog & "[debug]   ERROR getting pos/size: " & errMsg & linefeed
            end try
            exit repeat
          end if
        end repeat
      end tell
    else
      set debugLog to debugLog & "[debug] Not found: " & appStr & linefeed
    end if
  end repeat
end tell
return debugLog & "---OUTPUT---" & linefeed & output
OSA
  2>&1)
  # Split debug from output
  echo "$result" | sed -n '/\[debug\]/p' >&2
  echo "$result" | sed -n '/---OUTPUT---/,$ p' | tail -n +2
}

detect_meeting_apps() {
  local screen_bounds
  screen_bounds=$(get_screen_bounds || true)
  if [[ -z "$screen_bounds" ]]; then
    return 0
  fi

  local window_data
  window_data=$(get_meeting_app_windows || true)
  if [[ -z "$window_data" ]]; then
    echo "No meeting apps detected" >&2
    return 0
  fi

  local screen_devices
  screen_devices=$(list_screens || true)
  if [[ -z "$screen_devices" ]]; then
    return 0
  fi

  local output
  output=$(SCREEN_BOUNDS="$screen_bounds" WINDOW_DATA="$window_data" SCREEN_DEVICES="$screen_devices" python3 - <<'PY' || true
import os
import re
from collections import Counter

def parse_lines(raw, expected):
    lines = []
    for line in raw.strip().splitlines():
        parts = line.split("\t")
        if len(parts) != expected:
            continue
        lines.append(parts)
    return lines

screen_bounds = parse_lines(os.environ.get("SCREEN_BOUNDS", ""), 5)
window_data = parse_lines(os.environ.get("WINDOW_DATA", ""), 5)
screen_devices = parse_lines(os.environ.get("SCREEN_DEVICES", ""), 3)

import sys
print(f"[debug] Python: screen_bounds={screen_bounds}", file=sys.stderr)
print(f"[debug] Python: window_data={window_data}", file=sys.stderr)
print(f"[debug] Python: screen_devices={screen_devices}", file=sys.stderr)

if not screen_bounds or not window_data or not screen_devices:
    print("[debug] Python: missing data, exiting", file=sys.stderr)
    raise SystemExit(0)

screens = []
for idx, x, y, w, h in screen_bounds:
    try:
        sx = float(x)
        sy = float(y)
        sw = float(w)
        sh = float(h)
        screens.append({
            "idx": int(idx),
            "x1": sx,
            "y1": sy,
            "x2": sx + sw,
            "y2": sy + sh,
        })
    except ValueError:
        continue

capture_to_device = {}
for dev_idx, name, _label in screen_devices:
    m = re.match(r"Capture screen (\d+)", name)
    if m:
        capture_to_device[int(m.group(1))] = dev_idx

if not capture_to_device:
    raise SystemExit(0)

detected = []
for app, x, y, w, h in window_data:
    try:
        cx = float(x) + float(w) / 2.0
        cy = float(y) + float(h) / 2.0
    except ValueError:
        continue
    screen_idx = None
    for s in screens:
        if cx >= s["x1"] and cx <= s["x2"] and cy >= s["y1"] and cy <= s["y2"]:
            screen_idx = s["idx"]
            break
    if screen_idx is None:
        continue
    if screen_idx not in capture_to_device:
        continue
    detected.append((app, screen_idx))

if not detected:
    raise SystemExit(0)

counts = Counter([s for _app, s in detected])
recommended = counts.most_common(1)[0][0]
device_idx = capture_to_device.get(recommended)

print("Detected meeting apps:")
for app, sidx in detected:
    print(f"  {app} -> Capture screen {sidx}")
print("")
print(f"Recommended screen: {device_idx} (Capture screen {recommended})")
PY
)

  if [[ -n "$output" ]]; then
    echo "$output" >&2
  fi
}

read_config() {
  CONFIG_SCREEN=""
  CONFIG_SYS_AUDIO=""
  CONFIG_MIC_AUDIO=""
  if [[ ! -f "$CONFIG_FILE" ]]; then
    return
  fi
  while IFS='=' read -r key value; do
    case "$key" in
      screen) CONFIG_SCREEN="$value" ;;
      system_audio) CONFIG_SYS_AUDIO="$value" ;;
      mic) CONFIG_MIC_AUDIO="$value" ;;
      *) ;;
    esac
  done < "$CONFIG_FILE"
}

write_config() {
  ensure_dirs
  cat <<EOF > "$CONFIG_FILE"
screen=$CONFIG_SCREEN
system_audio=$CONFIG_SYS_AUDIO
mic=$CONFIG_MIC_AUDIO
EOF
}

index_to_name() {
  local type="$1"
  local idx="$2"
  if [[ "$type" == "audio" ]]; then
    list_audio_devices | awk -v want="$idx" -F'\t' '$1==want {print $2; exit}'
  else
    list_screens | awk -v want="$idx" -F'\t' '$1==want {print $2; exit}'
  fi
}

name_to_index() {
  local type="$1"
  local name="$2"
  if [[ "$name" =~ ^[0-9]+$ ]]; then
    if [[ "$type" == "audio" ]]; then
      if list_audio_devices | awk '{print $1}' | grep -qx "$name"; then
        echo "$name"
        return
      fi
    else
      if list_screens | awk '{print $1}' | grep -qx "$name"; then
        echo "$name"
        return
      fi
    fi
  fi
  if [[ "$type" == "audio" ]]; then
    list_audio_devices | awk -v want="$name" -F'\t' '$2==want {print $1; exit}'
  else
    list_screens | awk -v want="$name" -F'\t' '$2==want {print $1; exit}'
  fi
}

pick_screen_interactive() {
  local devices
  devices=$(list_screens || true)
  if [[ -z "$devices" ]]; then
    echo "No video devices found. Try: ffmpeg -f avfoundation -list_devices true -i \"\"" >&2
    exit 1
  fi

  echo "Available screens:" >&2
  echo "$devices" | awk -F'\t' '{printf "  [%s] %s (%s)\n", $1, $2, $3}' >&2
  read -r -p "Select screens (e.g. 0,1 or all). Blank for all: " selection
  if [[ -z "$selection" || "$selection" == "all" ]]; then
    echo "all"
    return
  fi

  local result=()
  local token
  IFS=',' read -r -a tokens <<< "$selection"
  for token in "${tokens[@]}"; do
    token="${token// /}"
    if [[ -z "$token" ]]; then
      continue
    fi
    if ! echo "$devices" | awk '{print $1}' | grep -qx "$token"; then
      echo "Unknown screen selection: $token" >&2
      exit 1
    fi
    result+=("$token")
  done

  if [[ "${#result[@]}" -eq 0 ]]; then
    echo "all"
  else
    local joined
    joined=$(IFS=','; echo "${result[*]}")
    echo "$joined"
  fi
}

pick_audio_interactive() {
  local label="$1"
  local devices
  devices=$(list_audio_devices || true)
  if [[ -z "$devices" ]]; then
    echo "No audio devices found. Try: ffmpeg -f avfoundation -list_devices true -i \"\"" >&2
    exit 1
  fi

  echo "Available audio devices:" >&2
  echo "$devices" | awk -F'\t' '{printf "  [%s] %s\n", $1, $2}' >&2
  local chosen=""
  read -r -p "Select $label device index (blank for first): " chosen
  if [[ -z "$chosen" ]]; then
    echo "$devices" | awk 'NR==1 {print $1}'
    return
  fi
  if echo "$devices" | awk '{print $1}' | grep -qx "$chosen"; then
    echo "$chosen"
    return
  fi
  echo "Unknown audio selection: $chosen" >&2
  exit 1
}

resolve_screen_selection() {
  local desired="$1"
  local devices
  devices=$(list_screens || true)
  if [[ -z "$devices" ]]; then
    echo ""
    return
  fi
  if [[ -z "$desired" || "$desired" == "all" ]]; then
    echo "all"
    return
  fi

  local indices=()
  local name
  IFS=',' read -r -a names <<< "$desired"
  for name in "${names[@]}"; do
    name="${name# }"
    name="${name% }"
    local idx
    idx=$(name_to_index video "$name")
    if [[ -z "$idx" ]]; then
      echo ""
      return
    fi
    indices+=("$idx")
  done

  local joined
  joined=$(IFS=','; echo "${indices[*]}")
  echo "$joined"
}

record_signal_ok() {
  local idx="$1"
  local max_vol
  max_vol=$(ffmpeg -nostdin -t 3 -f avfoundation -i ":${idx}" -af "volumedetect" -f null - 2>&1 | awk '/max_volume:/ {print $5; exit}')
  if [[ -z "$max_vol" ]]; then
    return 1
  fi
  python3 - <<PY
import sys
try:
    val=float("${max_vol}")
except ValueError:
    sys.exit(1)
sys.exit(0 if val > float("${SILENCE_THRESHOLD_DB}") else 1)
PY
}

get_video_indices() {
  parse_devices video | while IFS= read -r line; do
    local idx
    idx="${line%%]*}"
    idx="${idx#*[}"
    echo "$idx"
  done
}

build_video_filter() {
  local count="$1"
  if [[ "$count" -le 1 ]]; then
    echo ""
    return
  fi

  local cols rows
  cols=$(python3 - <<PY
import math
c=int($count)
print(int(math.ceil(math.sqrt(c))))
PY
)
  rows=$(python3 - <<PY
import math
c=int($count)
cols=int($cols)
print(int(math.ceil(c/cols)))
PY
)

  local layout_parts=()
  local i r c x y
  for ((i=0;i<count;i++)); do
    r=$((i / cols))
    c=$((i % cols))
    if [[ $c -eq 0 ]]; then
      x="0"
    else
      x="w0*${c}"
    fi
    if [[ $r -eq 0 ]]; then
      y="0"
    else
      y="h0*${r}"
    fi
    layout_parts+=("${x}_${y}")
  done

  local layout
  layout=$(IFS='|'; echo "${layout_parts[*]}")
  echo "xstack=inputs=${count}:layout=${layout}"
}

format_duration() {
  local seconds="$1"
  if [[ -z "$seconds" ]]; then
    echo "N/A"
    return
  fi
  python3 - <<PY
import math
s=float("$seconds")
if s < 0:
  s=0
h=int(s//3600)
m=int((s%3600)//60)
sec=int(s%60)
print(f"{h:02d}:{m:02d}:{sec:02d}")
PY
}

start_recording() {
  ensure_dirs
  local screen_arg="${1:-}"
  read_config

  local screen_sel=""
  local screen_names=""
  local sys_audio=""
  local mic_audio=""
  local sys_name=""
  local mic_name=""

  if [[ -n "$screen_arg" ]]; then
    if [[ "$screen_arg" == "all" ]]; then
      screen_sel="all"
    else
      screen_sel=$(resolve_screen_selection "$screen_arg")
    fi
    if [[ -z "$screen_sel" ]]; then
      echo "Unknown screen selection: $screen_arg" >&2
      exit 1
    fi
  elif [[ -n "$CONFIG_SCREEN" ]]; then
    screen_sel=$(resolve_screen_selection "$CONFIG_SCREEN")
    screen_names="$CONFIG_SCREEN"
  fi

  if [[ -z "$screen_sel" ]]; then
    echo "Saved screen selection not found. Please choose again." >&2
    screen_sel=$(pick_screen_interactive)
  fi

  if [[ "$screen_sel" == "all" ]]; then
    screen_names="all"
  else
    local idx
    local names=()
    IFS=',' read -r -a indices <<< "$screen_sel"
    for idx in "${indices[@]}"; do
      names+=("$(index_to_name video "$idx")")
    done
    screen_names=$(IFS=', '; echo "${names[*]}")
  fi

  local desired_sys="${MEETING_SYS_AUDIO:-$CONFIG_SYS_AUDIO}"
  local desired_mic="${MEETING_MIC_AUDIO:-$CONFIG_MIC_AUDIO}"

  if [[ -n "$desired_sys" ]]; then
    sys_audio=$(name_to_index audio "$desired_sys" || true)
    sys_name="$desired_sys"
  fi
  if [[ -n "$desired_mic" ]]; then
    mic_audio=$(name_to_index audio "$desired_mic" || true)
    mic_name="$desired_mic"
  fi

  if [[ -z "$sys_audio" ]]; then
    echo "Saved system audio device not found. Please choose again." >&2
    sys_audio=$(pick_audio_interactive "system audio")
    sys_name=$(index_to_name audio "$sys_audio")
  fi
  if [[ -z "$mic_audio" ]]; then
    echo "Saved microphone device not found. Please choose again." >&2
    mic_audio=$(pick_audio_interactive "microphone")
    mic_name=$(index_to_name audio "$mic_audio")
  fi

  if [[ "$sys_name" =~ ^[0-9]+$ || -z "$sys_name" ]]; then
    sys_name=$(index_to_name audio "$sys_audio")
  fi
  if [[ "$mic_name" =~ ^[0-9]+$ || -z "$mic_name" ]]; then
    mic_name=$(index_to_name audio "$mic_audio")
  fi

  CONFIG_SCREEN="$screen_names"
  CONFIG_SYS_AUDIO="$sys_name"
  CONFIG_MIC_AUDIO="$mic_name"
  write_config

  local ts dir
  ts=$(date "+%Y-%m-%d_%H-%M")
  dir="$MEETINGS_DIR/$ts"
  mkdir -p "$dir"

  local recording="$dir/recording.mov"
  local log="$dir/recording.log"

  echo "Starting recording. macOS may prompt for Screen Recording permission." >&2

  local all_indices video_indices
  mapfile -t all_indices < <(get_video_indices)
  if [[ "$screen_sel" == "all" ]]; then
    video_indices=("${all_indices[@]}")
  else
    IFS=',' read -r -a video_indices <<< "$screen_sel"
  fi
  local video_input_count=${#video_indices[@]}

  local filter
  filter=$(build_video_filter "$video_input_count")

  local cmd=(ffmpeg -y)
  for idx in "${video_indices[@]}"; do
    cmd+=("-f" "avfoundation" "-framerate" "30" "-capture_cursor" "1" "-i" "${idx}:none")
  done
  cmd+=( -f avfoundation -i ":${sys_audio}")
  if [[ "$mic_audio" != "$sys_audio" ]]; then
    cmd+=( -f avfoundation -i ":${mic_audio}")
  fi

  local ainputs
  local vmap="0:v"
  local amap
  if [[ -n "$filter" ]]; then
    vmap="[v]"
  fi

  if [[ "$mic_audio" != "$sys_audio" ]]; then
    local sys_audio_index="$video_input_count"
    local mic_audio_index=$((video_input_count+1))
    ainputs="[${sys_audio_index}:a][${mic_audio_index}:a]"
    amap="[a]"
  else
    local sys_audio_index="$video_input_count"
    ainputs="[${sys_audio_index}:a]"
    amap="[a]"
  fi

  if [[ -n "$filter" || "$mic_audio" != "$sys_audio" ]]; then
    local fc=""
    if [[ -n "$filter" ]]; then
      fc+="$filter[v]"
    fi
    if [[ "$mic_audio" != "$sys_audio" ]]; then
      if [[ -n "$fc" ]]; then fc+=";"; fi
      fc+="$ainputs amix=inputs=2:normalize=0[a]"
    else
      if [[ -n "$fc" ]]; then fc+=";"; fi
      fc+="$ainputs anull[a]"
    fi
    cmd+=( -filter_complex "$fc" -map "$vmap" -map "$amap" )
  else
    cmd+=( -map 0:v -map ${video_input_count}:a )
  fi

  cmd+=( -c:v libx264 -preset veryfast -crf 23 -c:a aac -b:a 192k "$recording" )

  "${cmd[@]}" >"$log" 2>&1 &
  local pid=$!

  echo "pid=$pid" > "$STATE_FILE"
  echo "dir=$dir" >> "$STATE_FILE"
  echo "start=$(date +%s)" >> "$STATE_FILE"

  echo "Recording started in $dir" >&2
  echo "$dir"
}

test_setup() {
  ensure_dirs
  read_config

  local screens
  screens=$(list_screens || true)
  if [[ -z "$screens" ]]; then
    echo "No video devices found. Try: ffmpeg -f avfoundation -list_devices true -i \"\"" >&2
    exit 1
  fi

  echo "Screens:" >&2
  echo "$screens" | awk -F'\t' '{printf "  [%s] %s (%s)\n", $1, $2, $3}' >&2

  local audio
  audio=$(list_audio_devices || true)
  if [[ -z "$audio" ]]; then
    echo "No audio devices found. Try: ffmpeg -f avfoundation -list_devices true -i \"\"" >&2
    exit 1
  fi

  echo "Audio devices:" >&2
  echo "$audio" | awk -F'\t' '{printf "  [%s] %s\n", $1, $2}' >&2

  detect_meeting_apps

  local screen_sel
  screen_sel=$(pick_screen_interactive)
  local sys_audio
  sys_audio=$(pick_audio_interactive "system audio")
  local mic_audio
  mic_audio=$(pick_audio_interactive "microphone")

  local screen_names=""
  if [[ "$screen_sel" == "all" ]]; then
    screen_names="all"
  else
    local idx
    local names=()
    IFS=',' read -r -a indices <<< "$screen_sel"
    for idx in "${indices[@]}"; do
      names+=("$(index_to_name video "$idx")")
    done
    screen_names=$(IFS=', '; echo "${names[*]}")
  fi

  local sys_name
  sys_name=$(index_to_name audio "$sys_audio")
  local mic_name
  mic_name=$(index_to_name audio "$mic_audio")

  echo "Testing system audio for 3 seconds..." >&2
  if record_signal_ok "$sys_audio"; then
    echo "System audio signal: ✅" >&2
  else
    echo "System audio signal: ❌" >&2
  fi

  echo "Say something now..." >&2
  if record_signal_ok "$mic_audio"; then
    echo "Microphone signal: ✅" >&2
  else
    echo "Microphone signal: ❌" >&2
  fi

  CONFIG_SCREEN="$screen_names"
  CONFIG_SYS_AUDIO="$sys_name"
  CONFIG_MIC_AUDIO="$mic_name"
  write_config

  echo "Saved config to $CONFIG_FILE" >&2
}

stop_recording() {
  if [[ ! -f "$STATE_FILE" ]]; then
    echo "No active recording found." >&2
    exit 1
  fi

  local pid dir start
  pid=$(awk -F= '/^pid=/ {print $2}' "$STATE_FILE")
  dir=$(awk -F= '/^dir=/ {print $2}' "$STATE_FILE")
  start=$(awk -F= '/^start=/ {print $2}' "$STATE_FILE")

  if [[ -z "$pid" || -z "$dir" ]]; then
    echo "State file corrupted." >&2
    exit 1
  fi

  if kill -0 "$pid" 2>/dev/null; then
    kill -INT "$pid"
    wait "$pid" 2>/dev/null || true
  fi

  rm -f "$STATE_FILE"

  local recording="$dir/recording.mov"
  local audio="$dir/audio.wav"
  local transcript="$dir/transcript.txt"
  local notes="$dir/notes.md"

  if [[ -f "$recording" ]]; then
    ffmpeg -y -i "$recording" -vn -ac 1 -ar 16000 "$audio" >/dev/null 2>&1 || true
  fi

  local transcribed=false
  if command -v whisper >/dev/null 2>&1; then
    whisper "$audio" --model base --language en --output_format txt --output_dir "$dir" >/dev/null 2>&1 || true
    if [[ -f "$dir/audio.txt" ]]; then
      mv "$dir/audio.txt" "$transcript"
    fi
    transcribed=true
  elif command -v whisper-cpp >/dev/null 2>&1; then
    whisper-cpp -m "${WHISPER_MODEL:-base}" -f "$audio" -otxt -of "$dir/transcript" >/dev/null 2>&1 || true
    if [[ -f "$dir/transcript.txt" ]]; then
      transcribed=true
    fi
  elif command -v whisper-cli >/dev/null 2>&1; then
    whisper-cli -m "${WHISPER_MODEL:-base}" -f "$audio" -otxt -of "$dir/transcript" >/dev/null 2>&1 || true
    if [[ -f "$dir/transcript.txt" ]]; then
      transcribed=true
    fi
  fi

  if [[ "$transcribed" != true ]]; then
    echo "Transcription skipped (whisper not found)." >&2
    : > "$transcript"
  fi

  local date_label
  date_label=$(date "+%Y-%m-%d %H:%M")

  local prompt
  prompt=$(cat <<EOF
Generate meeting notes in this exact format:

# Meeting Notes — $date_label

## Summary
Brief 2-3 sentence overview

## Key Discussion Points
- Point 1
- Point 2

## Decisions Made
- Decision 1
- Decision 2

## Action Items
- [ ] Action item (@person if mentioned)

## Follow-ups
- Follow-up item

## Raw Transcript
[link to transcript.txt]

Use the transcript below. Keep headings and structure exactly the same.
EOF
)

  if command -v claude >/dev/null 2>&1; then
    {
      echo "$prompt"
      echo ""
      echo "Transcript:"
      cat "$transcript"
    } | claude > "$notes" 2>/dev/null || true
  fi

  if [[ ! -s "$notes" ]]; then
    cat <<EOF > "$notes"
# Meeting Notes — $date_label

## Summary
(Claude CLI not available or failed to generate notes.)

## Key Discussion Points
- 

## Decisions Made
- 

## Action Items
- [ ] 

## Follow-ups
- 

## Raw Transcript
transcript.txt
EOF
  fi

  local end
  end=$(date +%s)
  local duration
  duration=$((end - start))
  echo "duration=$duration" > "$dir/meeting.meta"

  echo "Recording stopped. Files saved to $dir" >&2
}

list_meetings() {
  ensure_dirs
  local dirs
  dirs=$(ls -1d "$MEETINGS_DIR"/* 2>/dev/null | sort -r || true)
  if [[ -z "$dirs" ]]; then
    echo "No meetings found." >&2
    return
  fi

  local idx=1
  while IFS= read -r dir; do
    local name
    name=$(basename "$dir")
    local duration="N/A"
    if [[ -f "$dir/meeting.meta" ]]; then
      duration=$(awk -F= '/^duration=/ {print $2}' "$dir/meeting.meta")
      duration=$(format_duration "$duration")
    elif command -v ffprobe >/dev/null 2>&1 && [[ -f "$dir/recording.mov" ]]; then
      duration=$(ffprobe -v error -show_entries format=duration -of default=nw=1:nk=1 "$dir/recording.mov" 2>/dev/null || true)
      duration=$(format_duration "$duration")
    fi

    local summary=""
    if [[ -f "$dir/notes.md" ]]; then
      summary=$(awk '/^## Summary/ {getline; while ($0=="" && getline) {}; print; exit}' "$dir/notes.md")
    fi

    printf "%2d. %s  (%s)  %s\n" "$idx" "$name" "$duration" "$summary"
    idx=$((idx+1))
  done <<< "$dirs"
}

resolve_meeting_dir() {
  local id="${1:-}"
  local dirs
  dirs=$(ls -1d "$MEETINGS_DIR"/* 2>/dev/null | sort -r || true)
  if [[ -z "$dirs" ]]; then
    echo ""; return
  fi

  if [[ -z "$id" ]]; then
    echo "$dirs" | head -n1
    return
  fi

  if [[ -d "$MEETINGS_DIR/$id" ]]; then
    echo "$MEETINGS_DIR/$id"
    return
  fi

  if [[ "$id" =~ ^[0-9]+$ ]]; then
    local dir
    dir=$(echo "$dirs" | awk -v n="$id" 'NR==n {print $0}')
    if [[ -n "$dir" ]]; then
      echo "$dir"
      return
    fi
  fi

  echo ""
}

show_notes() {
  local id="${1:-}"
  local dir
  dir=$(resolve_meeting_dir "$id")
  if [[ -z "$dir" ]]; then
    echo "Meeting not found." >&2
    exit 1
  fi

  if [[ -f "$dir/notes.md" ]]; then
    cat "$dir/notes.md"
  else
    echo "Notes not found for $dir" >&2
    exit 1
  fi
}

search_meetings() {
  local query="${1:-}"
  if [[ -z "$query" ]]; then
    echo "Usage: meeting search <query>" >&2
    exit 1
  fi

  if command -v rg >/dev/null 2>&1; then
    rg -n --heading "$query" "$MEETINGS_DIR"/ -g 'notes.md' -g 'transcript.txt'
  else
    grep -R -n "$query" "$MEETINGS_DIR"/ || true
  fi
}

usage() {
  cat <<EOF
Usage: meeting <command>

Commands:
  start [screen]   Start screen recording (default: all screens)
  test             One-time setup to pick devices and verify audio signal
  stop             Stop recording and generate transcript + notes
  list             List past meetings
  notes [id]        Show notes for a meeting (id from list or folder name)
  search <query>   Search transcripts and notes
EOF
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    start)
      shift
      start_recording "${1:-}"
      ;;
    test)
      test_setup
      ;;
    stop)
      stop_recording
      ;;
    list)
      list_meetings
      ;;
    notes)
      shift
      show_notes "${1:-}"
      ;;
    search)
      shift
      search_meetings "${1:-}"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
